# Caddyfile for PRODUCTION (HTTPS with Let's Encrypt)
# Usage: cp Caddyfile.prod Caddyfile on the server BEFORE running docker compose up
# Requires DOMAIN_NAME env var (e.g. optitoken.net) to be set and DNS pointing to the server.

{$DOMAIN_NAME:optitoken.net} {
    encode zstd gzip

    # Reverse-proxy /v1/* to the Go proxy (LLM gateway)
    handle /v1/* {
        reverse_proxy proxy:8080
    }

    # Everything else goes to the Next.js dashboard
    handle /* {
        reverse_proxy dashboard:3000
    }
}
