# Synapse Proxy Dashboard — environment template
#
# Copy this file to `.env` and fill in the values for your setup.
# Never commit a real `.env`. The values below are placeholders only.
#
# Generate a fresh NEXTAUTH_SECRET with:
#   openssl rand -hex 32
# Generate a fresh ENCRYPTION_KEY with:
#   openssl rand -hex 16    # 32 hex chars

# --- Database (Postgres) ---
# Connection string for the Postgres database used by Prisma.
# Format: postgresql://<user>:<password>@<host>:<port>/<db>?schema=public
DATABASE_URL="postgresql://optitoken:CHANGE_ME@localhost:5432/optitoken_db?schema=public"

# --- NextAuth ---
# Random secret used to sign session JWTs. Rotate every 90 days.
NEXTAUTH_SECRET="CHANGE_ME_32_BYTES_HEX"

# Public URL of the dashboard, used by NextAuth for callbacks.
NEXTAUTH_URL="http://localhost:3000"

# --- Encryption ---
# 32-character hex key used to encrypt provider API keys at rest
# in the ApiKey table (column "real_key"). Rotating this invalidates
# every stored provider key, so plan carefully.
ENCRYPTION_KEY="CHANGE_ME_32_HEX_CHARS"

# --- Proxy ---
# Internal URL of the Synapse Proxy data plane. The dashboard uses
# this for direct server-side calls when proxying MCP tools; for
# most user-facing flows the proxy is reached via the public URL
# (synapse-proxy.com) instead.
PROXY_URL="http://localhost:8080"