{
  "name": "@synapse-proxy/sdk",
  "version": "0.1.0",
  "description": "Drop-in OpenAI-compatible client for Synapse Proxy with session recording, cache stats, and A/B benchmark extensions",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "synapse-proxy",
    "llm",
    "caching",
    "observability",
    "openai-compatible",
    "agent"
  ],
  "author": "Synapse Proxy <contact@synapse-proxy.com>",
  "homepage": "https://synapse-proxy.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/dudutti/synapse-proxy-sdk"
  },
  "bugs": {
    "url": "https://github.com/dudutti/synapse-proxy-sdk/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "openai": "^4.50.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "prettier": "^3.2.0",
    "nock": "^13.5.0"
  }
}
